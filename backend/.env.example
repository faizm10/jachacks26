# Comma-separated origins for browser calls from Next.js (include 127.0.0.1 if you use that host)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
#
# Where corridor calibrations are persisted (default: backend/calibrations.json next to this app)
# CALIBRATIONS_PATH=/absolute/path/calibrations.json

# Motion-map pipeline (optional tuning)
# FLOORPLAN_MAX_BYTES=26214400
# FLOORPLAN_MAX_SECONDS=12
# FLOORPLAN_FRAME_STRIDE=2
# FLOORPLAN_GRID_W=32
# FLOORPLAN_GRID_H=24
#
# IMG_5530 corridor warp: motion in video ROI (x,y,w,h %) → floor plan ROI (%). Tune to your clip + PNG.
# FLOORPLAN_IMG5530_VIDEO_ROI=8,20,84,58
# FLOORPLAN_IMG5530_FLOOR_ROI=6,44,88,12
