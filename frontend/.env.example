# Python backend — required for POST /floorplan/analyze (spatial motion map from selected video)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Supabase (camera feed from Storage) ---
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use either legacy anon key or new publishable key (same value in dashboard)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Storage bucket id — must match Supabase exactly (yours: cam). Default: cam
# NEXT_PUBLIC_CAMS_BUCKET=cam

# Optional: subfolder *inside* the bucket only (e.g. uploads). NOT the bucket name. Leave unset if files are at bucket root.
# NEXT_PUBLIC_CAMS_PREFIX=uploads

# Poll for newest file this often (ms). Min 2000.
# NEXT_PUBLIC_CAMS_POLL_INTERVAL_MS=5000

# If the bucket is private, set to "true" to use signed URLs (requires Storage policies that allow
# the anon key to read objects). If the bucket is public, leave unset or "false".
# NEXT_PUBLIC_CAMS_USE_SIGNED_URLS=false
